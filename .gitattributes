# Git LFS — large data files stored via LFS instead of inline in git history.
# Allows price CSVs and the SQLite DB to be pushed without bloating the repo.
data/prices/*.csv filter=lfs diff=lfs merge=lfs -text
data/sessions.db  filter=lfs diff=lfs merge=lfs -text
data/prices/* filter=lfs diff=lfs merge=lfs -text
