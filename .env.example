# Polygon wallet private key (hex, with or without 0x prefix)
PRIVATE_KEY=

# Your Polygon wallet address (funder address)
WALLET_ADDRESS=

# Derived from private key via create_or_derive_api_creds() — populated automatically on first run
# You can also set these manually if you already have them
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=
